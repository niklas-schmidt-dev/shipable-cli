{
  "name": "@shipable/cli",
  "version": "0.1.4",
  "description": "Shipable CLI for local app generation, sync, preview, and deployment workflows.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niklas-schmidt-dev/shipable-cli.git"
  },
  "bugs": {
    "url": "https://github.com/niklas-schmidt-dev/shipable-cli/issues"
  },
  "homepage": "https://github.com/niklas-schmidt-dev/shipable-cli#readme",
  "type": "commonjs",
  "bin": {
    "shipable": "bin/shipable.js"
  },
  "files": [
    "bin/shipable.js",
    "dist/SHA256SUMS",
    "dist/darwin-arm64/shipable",
    "dist/darwin-x64/shipable",
    "dist/linux-arm64/shipable",
    "dist/linux-x64/shipable",
    "dist/win32-arm64/shipable.exe",
